/* Signal(MACD) MACD Signal Crosses) ***********************************************/
MB= Cross (MACD(), Signal());
MS = Cross( Signal(), MACD());
MB = ExRem(MB, MS);
MS = ExRem(MS, MB);
MB1= MACD() > Signal();
MS1= MACD() < Signal();
prcOutPut(MB, MS, MB1, MS1,"MACD");

/* Signal(Stoch) Stochastics Part **************************************************/
StochKval = StochK(14,3);
StochDval = StochD(14,3,3);
StochBuy = Cross(StochKval, StochDval);
StochSell = Cross (StochDval, StochKval);
StBuy=StochKval>StochDval;
StSell=StochKval<StochDval;
prcOutPut(StochBuy, StochSell, StBuy, StSell,"Stoch");

/* Signal(P5/15) Breakout Setting *************************************************/
Buyperiods=Param("Breakout periods",5,1,100,1,1);
BuyBreakout= C>Ref(HHV(H,Buyperiods),-1);
Buyperiods2=Param("2 Breakout periods",17,1,100,1,1);
BuyBreakout2= Cross( C, Ref( HHV(H,Buyperiods2), -1 ) );
txtBuyBreakout = 
		WriteIf(Buybreakout, "BreakOut1",
		WriteIf(Buybreakout2>Buybreakout, "BreakOut2","Neutral"));
txtColoBuyBreakout = IIf(txtBuyBreakout ==	"BreakOut1", colorGreen,
					 IIf(txtBuyBreakout ==	"BreakOut2", colorGreen, colorGrey50));
AddTextColumn(txtBuyBreakout, "BreakP5/15", 1.2, colorWhite, txtColoBuyBreakout);


_SECTION_BEGIN("Breakout Signal");
 
_bBuy= C>Ref(HHV(High,5),-1) ;
_bSell= C<Ref(LLV(Low,5),-1);

/* exrem is one method to remove surplus strade signals. It removes excessive signals of arrow */
_bBuy1 = ExRem(_bBuy, _bSell);
_bSell1 = ExRem(_bSell, _bBuy);

prcOutPut(_bBuy1, _bSell1, _bBuy, _bSell,"BreakoutSignal");
 
 _SECTION_END();

/* Signal(Breakout) Breakout Setting ***********************************************/
txtBuyBreakout = 
		WriteIf(C>YY1, "BreakOut",
		WriteIf(C<XX1, "BreakDown","Neutral"));
txtColoBuyBreakout = IIf(txtBuyBreakout ==	"BreakOut", colorGreen,
					 IIf(txtBuyBreakout ==	"BreakDown", colorRed, colorGrey50));
AddTextColumn(txtBuyBreakout, "Breakout", 1.2, colorWhite, txtColoBuyBreakout);

addcolumn( MA(Volume,5), "MA_Volume", 1);
addcolumn( Close, "Close price", 1.2);

function fncolortxt(_c)
{
 return IIf(_c < 0, colorRed,
			IIf(_c > 0, colorGreen, colorGrey50));
}

_Close_1D = ((Close-Ref(Close,-1))*100/Ref(Close,-1));
addcolumn(_Close_1D, "P-1D", 1.2, colorWhite, fncolortxt(_Close_1D));

_Close_3D = (Close-Ref(Close,-3))*100/Ref(Close,-3);
addcolumn(_Close_3D, "P-3D", 1.2, colorWhite, fncolortxt(_Close_3D));

_Close_1W = (Close-Ref(Close,-5))*100/Ref(Close,-5);
addcolumn(_Close_1W, "P-1W", 1.2, colorWhite, fncolortxt(_Close_1W));

_Close_1M = (Close-Ref(Close,-20))*100/Ref(Close,-20);
addcolumn(_Close_1M, "P-1M", 1.2, colorWhite, fncolortxt(_Close_1M));

_Close_3M = (Close-Ref(Close,-60))*100/Ref(Close,-60);
addcolumn(_Close_3M, "P-3M", 1.2, colorWhite, fncolortxt(_Close_3M));

_Close_6M = (Close-Ref(Close,-120))*100/Ref(Close,-120);
addcolumn(_Close_6M, "P-6M", 1.2, colorWhite, fncolortxt(_Close_6M));

_Close_1Y = (Close-Ref(Close,-240))*100/Ref(Close,-240);
addcolumn(_Close_1Y, "P-1Y", 1.2, colorWhite, fncolortxt(_Close_1Y));

AddTextColumn(Name(), "Tick", 1.2);

_hhv_20 = hhv(High, 20);
_div = IIF( Close >= _hhv_20, (Close-_hhv_20)*100/_hhv_20, (Close-_hhv_20)*100/_hhv_20);
addcolumn(_div, "HHV_20", 1.2, colorWhite, IIf(_div < 0, colorRed, IIf(_div > 0, colorGreen, colorGrey50)));
_llv_20 = LLV(Low, 20);
_div = IIF( Close >= _llv_20, (Close-_llv_20)*100/_llv_20, (Close-_llv_20)*100/_llv_20);
addcolumn(_div, "LLV_20", 1.2, colorWhite, IIf(_div < 0, colorRed, IIf(_div > 0, colorGreen, colorGrey50)));

_hhv_50 = hhv(High, 50);
_div = IIF( Close >= _hhv_50, (Close-_hhv_50)*100/_hhv_50, (Close-_hhv_50)*100/_hhv_50);
addcolumn(_div, "HHV_50", 1.2, colorWhite, IIf(_div < 0, colorRed, IIf(_div > 0, colorGreen, colorGrey50)));
_llv_50 = LLV(Low, 50);
_div = IIF( Close >= _llv_50, (Close-_llv_50)*100/_llv_50, (Close-_llv_50)*100/_llv_50);
addcolumn(_div, "LLV_50", 1.2, colorWhite, IIf(_div < 0, colorRed, IIf(_div > 0, colorGreen, colorGrey50)));


_hhv_100 = hhv(High, 100);
_div = IIF( Close >= _hhv_100, (Close-_hhv_100)*100/_hhv_100, (Close-_hhv_100)*100/_hhv_100);
addcolumn(_div, "HHV_100", 1.2, colorWhite, IIf(_div < 0, colorRed, IIf(_div > 0, colorGreen, colorGrey50)));
_llv_100 = LLV(Low, 100);
_div = IIF( Close >= _llv_100, (Close-_llv_100)*100/_llv_100, (Close-_llv_100)*100/_llv_100);
addcolumn(_div, "LLV_100", 1.2, colorWhite, IIf(_div < 0, colorRed, IIf(_div > 0, colorGreen, colorGrey50)));

_hhv_200 = hhv(High, 200);
_div = IIF( Close >= _hhv_200, (Close-_hhv_200)*100/_hhv_200, (Close-_hhv_200)*100/_hhv_200);
addcolumn(_div, "HHV_200", 1.2, colorWhite, IIf(_div < 0, colorRed, IIf(_div > 0, colorGreen, colorGrey50)));
_llv_200 = LLV(Low, 200);
_div = IIF( Close >= _llv_200, (Close-_llv_200)*100/_llv_200, (Close-_llv_200)*100/_llv_200);
addcolumn(_div, "LLV_200", 1.2, colorWhite, IIf(_div < 0, colorRed, IIf(_div > 0, colorGreen, colorGrey50)));

addcolumn(C - SenkouSpanA, "Distance Span A", 1.2);
addcolumn(RSI(14), "RSI_14", 1.2);

Daysback = Param( "Days Back", 52, 30, 252, 1 );
bb = LastValue( LinRegSlope(C, Daysback ));
pi = 4 * atan(1);
slopeangle = atan( bb ) * ( 180 / pi );
AddColumn(slopeangle,"In degrees", colorDefault, colorBlue);
AddColumn(StdErr( 100 * Close, Daysback ),"Std.Err RS Line(%)", colorDefault, colorBlue);

_SECTION_END();


ForceIdx = EMA(((Close - Ref(Close, -1)) * V), 20);
//Filter = RSI(14) <=50;
Filter = 1 AND MA(V,5) >= 50000 //AND RSI(14) <=50 AND ForceIdx > 0
; //AND Close >= 2.5;
//AND _bBuy1;
//AND Close==High;

SetSortColumns(-5, -4, -3, -8, -18); 
