#include <T3_Include.afl>;
_startDate = DateTimeAdd( Now( 5 ), -13, inMonthly );
Filter = DateTime() >= _startDate;

_indi_MA =  IIf( Close < MA(Close, 200), 400
			, IIf( Close >= MA(Close, 5), 5
			, IIf( Close >= MA(Close, 10) AND Close < MA(Close, 5), 10
			, IIf( Close >= MA(Close, 20) AND Close < MA(Close, 10), 20
			, IIf( Close >= MA(Close, 50) AND Close < MA(Close, 20), 50
			, IIf( Close >= MA(Close, 100) AND Close < MA(Close, 50), 100
			, IIf( Close >= MA(Close, 200) AND Close < MA(Close, 100), 200
			, 0)))))));

// Add columns for exploration
AddColumn(Close, "Close");
AddColumn(_indi_MA, "MA", 1.0);

