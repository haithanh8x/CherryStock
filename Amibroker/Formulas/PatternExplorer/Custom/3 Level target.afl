b4=s-3.25;//stoploss upto 700
C4=s-5.25;//stoploss upto 1300
d4=s-10;// stoploss above 1300
//----------------------
 
 
 
a11=r+1.75;//sellstoploss upto300
b11=r+3.25;//700
C11=r+5.25;//1300
d11=r+10;//above1300
//-------------------------
