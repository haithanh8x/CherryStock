a1222=2.25*(a55-d4)+a55;//1300 to 3000
b1212=2.25*(b55-d4)+b55;//above 3000
 
//___________________________________________________________________________
 
//Selling 1st tgt
j7=2*j6-a11;//200
a7=2*a6-a11;//300
b7=2*b6-b11;//400
