a771=2*a66-d11;//1300 t03000
b77=2*b66-d11;//above 3000
 
 
//2nd tgt  1.5*1st
 
j27=1.5*(j6-a11)+j6;//200
a27=1.5*(a6-a11)+a6;//300
b27=1.5*(b6-b11)+b6;//400
d27=1.5*(d6-b11)+d6;//500
